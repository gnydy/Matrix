# Matrix Local — copy to .env
# NEVER commit .env to Git

COMPOSE_PROJECT_NAME=matrix-local

# PostgreSQL
POSTGRES_USER=matrix
POSTGRES_PASSWORD=matrix_dev_change_me
POSTGRES_DB=matrix_dev
POSTGRES_PORT=5432
DATABASE_URL=postgresql://matrix:matrix_dev_change_me@localhost:5432/matrix_dev

# Redis
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# Mail (Mailhog — dev only)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@matrix.local

# API (when apps/api is ready)
API_PORT=4000
JWT_SECRET=change_me_to_random_64_chars_in_production
JWT_EXPIRES_IN=7d

# Web apps
WEB_MARKETING_PORT=3000
WEB_PLATFORM_PORT=3001
WEB_ERP_PORT=3002

# n8n (optional — Sprint 5+)
# N8N_WEBHOOK_BASE_URL=
# MATRIX_AUTOMATION_TOKEN=

# Payments (fill when ready — see docs/specs/04-PAYMENT-APIS-REQUIREMENTS.md)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYMOB_API_KEY=
