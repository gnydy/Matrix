import { notFound } from 'next/navigation';
import {
  getPortfolioProjectBySlug,
  getVisiblePortfolioProjects,
} from '../../../lib/portfolio';
import { ProjectDetailsClient } from '../portfolio-ui';

export function generateStaticParams() {
  return getVisiblePortfolioProjects().map((project) => ({
    slug: project.slug,
  }));
}

export async function generateMetadata({
  params,
}: {
  params: Promise<{ slug: string }>;
}) {
  const { slug } = await params;
  const project = getPortfolioProjectBySlug(slug);

  if (!project) {
    return {
      title: 'Work not found | Matrix',
    };
  }

  return {
    title: `${project.titleEn} | Our Work | Matrix`,
    description: project.shortDescriptionEn,
  };
}

export default async function PortfolioDetailsPage({
  params,
}: {
  params: Promise<{ slug: string }>;
}) {
  const { slug } = await params;
  const project = getPortfolioProjectBySlug(slug);

  if (!project) {
    notFound();
  }

  return <ProjectDetailsClient project={project} />;
}