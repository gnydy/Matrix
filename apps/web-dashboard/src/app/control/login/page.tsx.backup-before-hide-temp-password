'use client';

import { useState } from 'react';
import { useRouter } from 'next/navigation';

export default function LoginPage() {
  const router = useRouter();

  const [password, setPassword] = useState('');
  const [error, setError] = useState('');
  const [loading, setLoading] = useState(false);

  async function submit(event: React.FormEvent<HTMLFormElement>) {
    event.preventDefault();

    setError('');
    setLoading(true);

    const response = await fetch('/api/auth/login', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ password }),
    });

    const json = await response.json();

    if (!response.ok || !json.ok) {
      setError(json.error ?? 'فشل تسجيل الدخول.');
      setLoading(false);
      return;
    }

    router.push('/control');
    router.refresh();
  }

  return (
    <main
      dir="rtl"
      style={{
        minHeight: '100vh',
        display: 'grid',
        placeItems: 'center',
        background:
          'radial-gradient(circle at top right, rgba(59, 130, 246, 0.22), transparent 34rem), #020617',
        color: '#f8fafc',
        padding: 20,
      }}
    >
      <form
        onSubmit={submit}
        style={{
          width: 'min(460px, 100%)',
          padding: 30,
          borderRadius: 28,
          background: '#0f172a',
          border: '1px solid rgba(148, 163, 184, 0.18)',
          boxShadow: '0 24px 70px rgba(0, 0, 0, 0.35)',
        }}
      >
        <div
          style={{
            width: 54,
            height: 54,
            borderRadius: 18,
            display: 'grid',
            placeItems: 'center',
            background: '#3b82f6',
            color: 'white',
            fontWeight: 950,
            fontSize: 22,
            marginBottom: 18,
          }}
        >
          M
        </div>

        <h1
          style={{
            margin: 0,
            fontSize: 34,
            letterSpacing: '-0.04em',
          }}
        >
          تسجيل دخول الداشبورد
        </h1>

        <p
          style={{
            marginTop: 10,
            color: '#94a3b8',
            lineHeight: 1.8,
          }}
        >
          هذه الصفحة محمية. أدخل كلمة مرور لوحة التحكم للوصول إلى الطلبات والإدارة.
        </p>

        <label
          style={{
            display: 'grid',
            gap: 8,
            marginTop: 22,
          }}
        >
          <span style={{ fontWeight: 900 }}>كلمة المرور</span>

          <input
            type="password"
            value={password}
            onChange={(event) => setPassword(event.target.value)}
            autoFocus
            required
            style={{
              minHeight: 52,
              borderRadius: 16,
              border: '1px solid rgba(148, 163, 184, 0.22)',
              background: '#020617',
              color: '#f8fafc',
              padding: '0 14px',
              outline: 'none',
              fontSize: 16,
            }}
          />
        </label>

        {error ? (
          <div
            style={{
              marginTop: 14,
              color: '#fca5a5',
              fontWeight: 900,
            }}
          >
            {error}
          </div>
        ) : null}

        <button
          type="submit"
          disabled={loading}
          style={{
            width: '100%',
            minHeight: 52,
            marginTop: 18,
            border: 0,
            borderRadius: 16,
            background: '#3b82f6',
            color: 'white',
            fontWeight: 950,
            cursor: loading ? 'not-allowed' : 'pointer',
            opacity: loading ? 0.7 : 1,
          }}
        >
          {loading ? 'جاري الدخول...' : 'دخول'}
        </button>

        <p
          style={{
            marginTop: 16,
            color: '#64748b',
            fontSize: 13,
            lineHeight: 1.7,
          }}
        >
          كلمة مرور التطوير المؤقتة: Matrix@12345. غيّرها من متغير DASHBOARD_PASSWORD.
        </p>
      </form>
    </main>
  );
}