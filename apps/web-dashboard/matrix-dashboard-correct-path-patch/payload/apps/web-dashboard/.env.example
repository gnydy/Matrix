# PostgreSQL used by @allinall/database
DATABASE_URL="postgresql://matrix:CHANGE_ME@127.0.0.1:5432/matrix?schema=public"

# Dashboard URL and cookie security
MATRIX_DASHBOARD_URL="http://127.0.0.1:3020"
MATRIX_DASHBOARD_SESSION_SECRET="GENERATE_AT_LEAST_64_RANDOM_HEX_CHARACTERS"
MATRIX_DASHBOARD_SESSION_DAYS="7"

# First-login bootstrap. Remove/rotate after creating the first owner account.
MATRIX_DASHBOARD_BOOTSTRAP_EMAIL="owner@matrix.local"
MATRIX_DASHBOARD_BOOTSTRAP_PASSWORD_HASH="scrypt$16384$8$1$SALT$HASH"

# Optional release metadata
MATRIX_RELEASE_SHA="local"
MATRIX_RELEASE_ENV="development"
