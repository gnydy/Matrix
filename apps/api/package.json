{
  "name": "@allinall/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:prod": "node dist/main.js",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:push": "prisma db push --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "setup": "pnpm run db:generate && pnpm run db:push && pnpm run db:seed"
  },
  "dependencies": {
    "@allinall/config": "workspace:*",
    "@allinall/contracts": "workspace:*",
    "@allinall/database": "workspace:*",
    "@allinall/erp": "workspace:*",
    "@allinall/security": "workspace:*",
    "@allinall/validation": "workspace:*",
    "@nestjs/common": "^10.4.20",
    "@nestjs/core": "^10.4.20",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.20",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "helmet": "^8.1.0",
    "jsonwebtoken": "latest",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "latest"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@types/bcryptjs": "latest",
    "@types/cors": "latest",
    "@types/express": "latest",
    "@types/jsonwebtoken": "latest",
    "@types/node": "^20.19.1",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.19.3",
    "tsx": "latest",
    "typescript": "latest"
  },
  "type": "module"
}