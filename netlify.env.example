# Netlify — متغيرات البيئة
# https://app.netlify.com/projects/cerulean-tartufo-5a529e/configuration/env

# PostgreSQL — إلزامي للنماذج
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# عنوان الموقع العام
NEXT_PUBLIC_SITE_URL=https://cerulean-tartufo-5a529e.netlify.app

# ─── Google Search Console (التحقق من الموقع) ───
# من: Search Console → إعدادات → ملكية → HTML tag
# انسخ قيمة content فقط (بدون علامات HTML)
GOOGLE_SITE_VERIFICATION=ضع_كود_التحقق_من_جوجل_هنا

# ─── إيميل عند طلب / تواصل جديد ───
# يُرسل إلى هذا البريد (الافتراضي: omargamal3107@gmail.com)
LEAD_NOTIFY_EMAIL=omargamal3107@gmail.com

# Gmail SMTP — أنشئ App Password من:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=omargamal3107@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM=omargamal3107@gmail.com
