# Netlify — متغيرات البيئة المطلوبة
# انسخ القيم في: Site settings → Environment variables
# https://app.netlify.com/projects/cerulean-tartufo-5a529e/configuration/env

# PostgreSQL (Neon / Netlify Database) — إلزامي للنماذج وتتبع الزوار
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# عنوان الموقع العام (بعد أول نشر)
NEXT_PUBLIC_SITE_URL=https://cerulean-tartufo-5a529e.netlify.app

# اختياري — فقط إذا نشرت Nest API على خادم خارجي لاحقاً
# NEXT_PUBLIC_API_URL=https://your-api.example.com
# MATRIX_API_URL=https://your-api.example.com
